# 1. 忽略所有環境變數與敏感金鑰（最關鍵！）
.env
.env.*
*.pem
*.key

# 2. 忽略 Python 快取與編譯檔案（避免 Image 肥大或權限衝突）
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# 3. 忽略版本控制與 IDE 設定
.git
.gitignore
.github/
.vscode/
.idea/
*.swp
.DS_Store

# 4. 忽略測試與報告檔案
.pytest_cache/
.coverage
htmlcov/
flake8/

# 5. 忽略 Docker 自身的建置檔案（非必要，但建議加上）
Dockerfile
docker-compose*.yml
.dockerignore